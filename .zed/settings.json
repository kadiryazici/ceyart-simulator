// Project-local Zed settings — mirrors .vscode/settings.json
{
  "format_on_save": "on",
  "linked_edits": true,
  "languages": {
    // Use tsgo instead of the default vtsls
    "TypeScript": {
      "language_servers": ["tsgo", "!vtsls", "..."],
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "TSX": {
      "language_servers": ["tsgo", "!vtsls", "..."],
      "formatter": "language_server",
      "format_on_save": "on",
    },
    "JavaScript": {
      "language_servers": ["tsgo", "!vtsls", "..."],
    },
  },
  "lsp": {
    "typescript-language-server": {
         "initialization_options": {
           "preferences": {
             "importModuleSpecifier": "non-relative",
             "includeInlayParameterNameHints": "literals",
             "includeInlayParameterNameHintsWhenArgumentMatchesName": false
           }
         }
       }
     },
    // Tailwind class detection in cva/cn/clsx etc.
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": [
          "cva",
          "cn",
          "clsx",
          "classNames",
          "classnames",
          "twMerge",
          "twc",
        ],
        "lint": {
          "suggestCanonicalClasses": "ignore",
        },
      },
    },
  },
}
